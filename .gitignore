# ============================================
# MOTORWAY OIL ENTERPRISE v4.0 — .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/

# Production build
dist/

# ============================================
# ENVIRONMENT FILES — NEVER COMMIT SECRETS
# ============================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging

# ============================================
# DEBUG & BUILD OUTPUTS
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
build_out.txt
build_output.txt
click_out.txt
debug_*.txt
git_*.txt
ts-*.txt
tsc-*.txt
vite-build.txt
output_test.txt
test_report.txt
verification_final.log
head_err.json
result.json

# ============================================
# BACKUP FILES — Use Git history instead
# ============================================
*.zip
*.tar.gz
*.bak
_backup_*/
*_backup_*/

# ============================================
# AUTO-GENERATED FILES
# ============================================
*.tsbuildinfo
next-env.d.ts
vite.config.d.ts
vite.config.js

# ============================================
# IDE
# ============================================
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# PLATFORM
# ============================================
.vercel/
.firebase/

# ============================================
# MISC
# ============================================
*.pem
.DS_Store
