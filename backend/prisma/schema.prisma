// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE MODELS ====================

model Organization {
  id                 String    @id @default(uuid())
  name               String
  subscriptionPlan   String?   @default("starter")
  subscriptionStatus String?   @default("trial")
  trialEndsAt        DateTime?
  settings           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  stations  Station[]
 users     User[]
  customers Customer[]
  suppliers Supplier[]

  @@map("organizations")
}

model Station {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  businessType   String
  address        String?
  latitude       Float?
  longitude      Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  fuelTanks    FuelTank[]
  fuelShifts   FuelShift[]
  fuelSales    FuelSale[]
  lubeProducts LubeProduct[]
  lubeSales    LubeSale[]
  cngShifts    CngShift[]
  expenses     Expense[]
  attendance   Attendance[]

  @@map("stations")
}

model User {
  id             String    @id @default(uuid())
  firebaseUid    String?   @unique
  email          String    @unique
  phone          String?
  fullName       String
  passwordHash   String?
  pin            String?
  photoURL       String?
  authMethod     String    @default("email")
  role           String    @default("operator")
  organizationId String
  stationId      String?
  businessUnit   String?   @default("FUEL")
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions     Session[]
  auditLogs    AuditLog[]
  attendance   Attendance[]

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  email     String?
  action    String
  status    String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ==================== FUEL MODELS ====================

model FuelTank {
  id           String   @id @default(uuid())
  stationId    String
  tankNumber   Int
  fuelType     String
  capacity     Float
  currentStock Float
  reorderLevel Float?
  iotDeviceId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  nozzles FuelNozzle[]

  @@unique([stationId, tankNumber])
  @@map("fuel_tanks")
}

model FuelNozzle {
  id             String   @id @default(uuid())
  tankId         String
  nozzleNumber   Int
  name           String
  currentReading Float
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tank           FuelTank @relation(fields: [tankId], references: [id], onDelete: Cascade)
  readings       FuelReading[]

  @@unique([tankId, nozzleNumber])
  @@map("fuel_nozzles")
}

model FuelShift {
  id           String    @id @default(uuid())
  stationId    String
  shiftNumber  Int
  startedById  String
  closedById   String?
  startTime    DateTime
  endTime      DateTime?
  openingCash  Float
  closingCash  Float?
  totalRevenue Float?    @default(0)
  expenses     Float?    @default(0)
  recoveries   Float?    @default(0)
  credits      Float?    @default(0)
  digitalCash  Float?    @default(0)
  bankDeposits Float?    @default(0)
  cashVariance Float?    @default(0)
  status       String    @default("open")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  station  Station       @relation(fields: [stationId], references: [id], onDelete: Cascade)
  sales    FuelSale[]
  readings FuelReading[]

  @@map("fuel_shifts")
}

model FuelReading {
  id           String   @id @default(uuid())
  shiftId      String
  nozzleId     String
  readingType  String // "OPENING" or "CLOSING"
  readingValue Float
  testVolume   Float    @default(0)
  timestamp    DateTime @default(now())

  shift  FuelShift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  nozzle FuelNozzle @relation(fields: [nozzleId], references: [id], onDelete: Cascade)

  @@map("fuel_readings")
}

model FuelSale {
  id             String   @id @default(uuid())
  stationId      String
  shiftId        String?
  pumpId         String?
  fuelType       String
  quantityLiters Float
  ratePerLiter   Float
  totalAmount    Float
  paymentMethod  String
  customerId     String?
  saleTime       DateTime @default(now())
  createdAt      DateTime @default(now())

  station Station    @relation(fields: [stationId], references: [id], onDelete: Cascade)
  shift   FuelShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([stationId, saleTime])
  @@map("fuel_sales")
}

// ==================== LUBE MODELS ====================

model LubeProduct {
  id           String   @id @default(uuid())
  stationId    String
  productId    String   @unique
  name         String
  brand        String?
  category     String?
  unit         String   @default("LITER")
  costPrice    Float
  salePrice    Float
  currentStock Int      @default(0)
  reorderLevel Int?
  barcode      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  station   Station        @relation(fields: [stationId], references: [id], onDelete: Cascade)
  saleItems LubeSaleItem[]

  @@map("lube_products")
}

model LubeSale {
  id              String   @id @default(uuid())
  stationId       String
  saleId          String   @unique
  customerId      String?
  totalAmount     Float
  discountPercent Float?
  discountAmount  Float?
  netAmount       Float
  paymentMethod   String
  soldById        String
  saleTime        DateTime @default(now())
  createdAt       DateTime @default(now())

  station Station        @relation(fields: [stationId], references: [id], onDelete: Cascade)
  items   LubeSaleItem[]

  @@map("lube_sales")
}

model LubeSaleItem {
  id         String   @id @default(uuid())
  saleId     String
  productId  String
  quantity   Int
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())

  sale    LubeSale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product LubeProduct @relation(fields: [productId], references: [id])

  @@map("lube_sale_items")
}

// ==================== CNG MODELS ====================

model CngShift {
  id           String    @id @default(uuid())
  stationId    String
  shiftNumber  Int
  startedById  String
  closedById   String?
  startTime    DateTime
  endTime      DateTime?
  openingCash  Float
  closingCash  Float?
  totalRevenue Float?    @default(0)
  totalLiters  Float?    @default(0) // KG in CNG context but kept as Liters/Quantity for consistency
  expenses     Float?    @default(0)
  recoveries   Float?    @default(0)
  credits      Float?    @default(0)
  digitalCash  Float?    @default(0)
  bankDeposits Float?    @default(0)
  cashVariance Float?    @default(0)
  status       String    @default("open")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  station  Station      @relation(fields: [stationId], references: [id], onDelete: Cascade)
  readings CngReading[]

  @@map("cng_shifts")
}

model CngNozzle {
  id             String   @id @default(uuid())
  stationId      String
  nozzleNumber   Int
  name           String
  currentReading Float
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  readings CngReading[]

  @@unique([stationId, nozzleNumber])
  @@map("cng_nozzles")
}

model CngReading {
  id           String   @id @default(uuid())
  shiftId      String
  nozzleId     String
  readingType  String // "OPENING" or "CLOSING"
  readingValue Float
  testVolume   Float    @default(0)
  timestamp    DateTime @default(now())

  shift  CngShift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  nozzle CngNozzle @relation(fields: [nozzleId], references: [id], onDelete: Cascade)

  @@map("cng_readings")
}

// ==================== FINANCIAL MODELS ====================

model Customer {
  id             String   @id @default(uuid())
  organizationId String
  customerId     String   @unique
  name           String
  phone          String?
  email          String?
  address        String?
  creditLimit    Float    @default(0)
  currentBalance Float    @default(0)
  customerType   String?  @default("retail")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("customers")
}

model Supplier {
  id             String   @id @default(uuid())
  organizationId String
  supplierId     String   @unique
  name           String
  phone          String?
  email          String?
  address        String?
  paymentTerms   String?
  currentBalance Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("suppliers")
}

model Expense {
  id            String   @id @default(uuid())
  stationId     String
  expenseId     String   @unique
  category      String
  amount        Float
  description   String?
  paymentMethod String?
  paidTo        String?
  expenseDate   DateTime
  approvedById  String?
  createdAt     DateTime @default(now())

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model Attendance {
  id            String    @id @default(uuid())
  userId        String
  stationId     String
  date          DateTime  @db.Date
  clockIn       DateTime  @default(now())
  clockOut      DateTime?
  status        String    @default("PRESENT")
  totalHours    Float?    @default(0)
  overtimeHours Float?    @default(0)
  businessUnit  String?   @default("FUEL")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([stationId, date])
  @@map("attendance")
}
