rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // 1. Users Collection
    // Users can only read and write their own profile document
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // 2. Stations Multi-Tenant Sandbox
    // Any authenticated user can access station data.
    // The stationId scoping is enforced by the application layer.
    // This removes the dependency on the /users/{uid} profile document
    // which was causing silent write failures on first login.
    match /stations/{stationId}/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    // 3. Fallback Deny All
    // Explicitly block all other database access vectors
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
